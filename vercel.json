{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/blog/", "destination": "/blog", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/ai-tools-beginners-guide", "destination": "/blog/ai-tools-beginners-guide.html" },
    { "source": "/blog/ai-tools-freelancers", "destination": "/blog/ai-tools-freelancers.html" },
    { "source": "/blog/best-ai-tools-personal-productivity", "destination": "/blog/best-ai-tools-personal-productivity.html" },
    { "source": "/blog/best-ai-tools-small-business", "destination": "/blog/best-ai-tools-small-business.html" },
    { "source": "/blog/chatgpt-vs-claude-vs-gemini", "destination": "/blog/chatgpt-vs-claude-vs-gemini.html" },
    { "source": "/blog/free-ai-tools-2026", "destination": "/blog/free-ai-tools-2026.html" },
    { "source": "/blog/how-to-choose-ai-tools-for-business", "destination": "/blog/how-to-choose-ai-tools-for-business.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com https://*.vercel-insights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://generativelanguage.googleapis.com https://fonts.googleapis.com https://fonts.gstatic.com; worker-src 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store, no-cache" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
